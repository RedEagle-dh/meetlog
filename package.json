{
    "name": "meetlog",
    "private": true,
    "workspaces": ["packages/*", "apps/*"],
    "scripts": {
        "dev": "turbo dev",
        "check-types": "turbo check-types",
        "db:generate": "bun run --parallel --filter @meetlog/db db:generate",
        "db:migrate": "bun run --parallel --filter @meetlog/db db:migrate",
        "db:studio": "bun run --parallel --filter @meetlog/db db:studio"
    },
    "packageManager": "bun@1.3.9",
    "dependencies": {
        "nitro": "npm:nitro-nightly@latest",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.2.4",
        "@typescript/native-preview": "latest",
        "turbo": "^2.8.11"
    }
}